# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# API
API_BASE_URL=http://gym-api:8000
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=sqlite:////data/gymops.db
TZ=Europe/Madrid

# Future Hermes / OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=15

# Hermes OAuth (usa tu login local de Hermes/Codex; sin OPENAI_API_KEY)
HERMES_OAUTH_ENABLED=false
HERMES_COMMAND=hermes
HERMES_PROVIDER=
HERMES_MODEL=
HERMES_TIMEOUT_SECONDS=45

# Host path for Docker bind mount (Hermes profile with OAuth credentials)
HERMES_HOME_HOST=/home/raspi/.hermes

# Grafana local access
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Nginx Proxy Manager (Fase 7 / Raspberry)
# Bind recomendado: solo localhost para panel admin, acceso por VPN o túnel SSH.
NPM_ADMIN_BIND=127.0.0.1:81
# Dominio raíz gestionado en Cloudflare.
PUBLIC_DOMAIN=a2technology.net
# Subdominios sugeridos para proxy hosts en NPM.
PUBLIC_API_SUBDOMAIN=gymops
PUBLIC_GRAFANA_SUBDOMAIN=grafana-gymops
