# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# Security
API_SECRET_KEY=replace_me_with_a_long_random_string
API_TIMEOUT_SECONDS=60
APP_ENV=rpi
HERMES_HOME_HOST=/home/${HOME}/.hermes
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
# IMPORTANT: NPM_ADMIN_BIND must be your LAN IP (e.g. 192.168.1.66:81).
# NEVER use 0.0.0.0 or leave it blank. The admin panel should NOT be exposed to the internet.
NPM_ADMIN_BIND=<IP_ADDRESS>:PORT
PUBLIC_DOMAIN=example.com
PUBLIC_API_SUBDOMAIN=gymops
PUBLIC_GRAFANA_SUBDOMAIN=grafana-gymops
HERMES_OAUTH_ENABLED=true
HERMES_COMMAND=hermes
HERMES_PROVIDER=
HERMES_MODEL=
HERMES_TIMEOUT_SECONDS=45
OPENAI_ENABLED=false

